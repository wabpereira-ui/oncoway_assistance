SECRET_KEY=gerar-com-openssl-rand-hex-32
DATABASE_URL=sqlite:///./mentoria.db
# PostgreSQL na VPS (exemplo):
# DATABASE_URL=postgresql+psycopg2://usuario:senha@localhost:5432/mentoria

# Cria o primeiro administrador só se o banco estiver vazio:
FIRST_ADMIN_EMAIL=admin@seudominio.com
FIRST_ADMIN_PASSWORD=senha-forte-aqui
FIRST_ADMIN_NAME=Administrador

# Senha inicial dos alunos quando o admin não informa outra ao criar o usuário (mín. 8 caracteres). Troque em produção.
DEFAULT_INITIAL_USER_PASSWORD=OncowayInicial8!

# Chat (OpenAI) — obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Modelo com visão (imagem + texto), ex.: gpt-4o, gpt-4o-mini
OPENAI_MODEL=gpt-4o
# Embeddings para busca nos materiais (RAG)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Opcional: pasta dos PDFs/TXT e quantidade de trechos enviados ao modelo
# MATERIALS_STORAGE_PATH=uploads/materials
# RAG_TOP_K=6
